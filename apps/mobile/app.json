{
    "expo": {
        "name": "BookACleaner",
        "slug": "bookacleaner",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "automatic",
        "scheme": "bookacleaner",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#0ea5e9"
        },
        "assetBundlePatterns": [
            "**/*"
        ],
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "ai.bookacleaner.app",
            "buildNumber": "1"
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#0ea5e9"
            },
            "package": "ai.bookacleaner.app",
            "versionCode": 1,
            "googleServicesFile": "./google-services.json"
        },
        "web": {
            "favicon": "./assets/favicon.png",
            "bundler": "metro"
        },
        "plugins": [
            "expo-router",
            [
                "expo-notifications",
                {
                    "icon": "./assets/notification-icon.png",
                    "color": "#0ea5e9"
                }
            ],
            "expo-secure-store"
        ],
        "extra": {
            "apiUrl": "https://api.bookacleaner.ai",
            "eas": {
                "projectId": "your-project-id"
            }
        }
    }
}