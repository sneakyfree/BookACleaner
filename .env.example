# ============================================================
# BookACleaner.ai — Environment Variables
# Copy to .env and fill in real values for production.
# ============================================================

# ---- Mode ----
DEV_MODE=true                                         # "false" in production

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://bookacleaner:password@localhost:5432/bookacleaner
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=10
# SQL_ECHO=false

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Celery ----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- Authentication ----
# IMPORTANT: Change JWT_SECRET and NEXTAUTH_SECRET in production!
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=your-super-secret-key-change-in-production

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PAY_AS_YOU_GO_PRICE_ID=price_...
STRIPE_WEEKLY_CLEAN_PRICE_ID=price_...
STRIPE_HOST_PRO_PRICE_ID=price_...

# ---- Twilio (SMS) ----
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# ---- SendGrid (Email) ----
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@bookacleaner.ai

# ---- OpenAI ----
OPENAI_API_KEY=sk-...

# ---- Google APIs ----
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# ---- AWS S3 (File Storage) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=bookacleaner-uploads
AWS_REGION=us-east-1
CDN_URL=                                              # Optional: CloudFront CDN URL

# ---- App / Frontend ----
NODE_ENV=development
FRONTEND_URL=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ---- Sentry (optional) ----
# SENTRY_DSN=https://...
