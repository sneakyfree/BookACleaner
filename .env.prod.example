# BookACleaner — production environment template
# Copy to `.env` next to docker-compose.prod.yml and fill in real values:
#   cp .env.prod.example .env && $EDITOR .env
#   docker compose -f docker-compose.prod.yml up -d --build
#
# Generate strong secrets with:  openssl rand -hex 32

# ---- Postgres ----
DB_USER=bookacleaner
DB_PASS=                      # REQUIRED — strong password
DB_NAME=bookacleaner
DB_PORT=5432

# ---- Redis ----
REDIS_PASS=                   # REQUIRED — strong password
REDIS_PORT=6379

# ---- App secrets (REQUIRED — app refuses to boot in prod without these) ----
JWT_SECRET=                   # openssl rand -hex 32
NEXTAUTH_SECRET=              # openssl rand -hex 32
INTERNAL_API_KEY=             # openssl rand -hex 32  (secures NextAuth -> backend calls)

# ---- Ports / URLs ----
API_PORT=8000
WEB_PORT=3000
API_URL=http://api:8000              # internal URL the web container/SSR uses
FRONTEND_URL=https://bookacleaner.ai # public site URL (NEXTAUTH_URL + CORS)

# ---- Stripe (live or test keys) ----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAY_AS_YOU_GO_PRICE_ID=
STRIPE_WEEKLY_CLEAN_PRICE_ID=
STRIPE_HOST_PRO_PRICE_ID=

# ---- Twilio (SMS / OTP) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ---- SendGrid (email) ----
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@bookacleaner.ai

# ---- OpenAI (GPT-4o features) ----
OPENAI_API_KEY=

# ---- Google (Maps / Places) ----
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# ---- AWS S3 (uploads / photos) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=bookacleaner-uploads
AWS_REGION=us-east-1

# ---- Sentry (optional error tracking) ----
SENTRY_DSN=
SENTRY_DSN_FRONTEND=

# ---- NextAuth secret already declared above (NEXTAUTH_SECRET) ----
NEXTAUTH_SECRET=
